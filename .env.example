OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-3.5-turbo

# Optional: Set to false to disable dark mode
DARK_MODE=true

# Optional: Set to false to show ignored files
HIDE_IGNORED_FILES=true

# Optional: Last project path (auto-filled)
LAST_PROJECT_PATH=/path/to/your/project

# Note: Do not commit your actual API key to version control.
# Copy this file to .env and replace the placeholder values.